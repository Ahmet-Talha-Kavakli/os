# Founder OS — ortam değişkenleri örneği
# Bu dosyayı .env.local olarak kopyala ve gerçek değerleri gir.
# .env.local ASLA git'e gitmez (.gitignore'da).

# AI asistan (Claude / Anthropic) — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# (opsiyonel) Görsel üretimi için Gemini
GEMINI_API_KEY=

# Workspace giriş şifresi — GÜÇLÜ bir değer gir (sen + ortağın bunu kullanır)
WORKSPACE_PASSWORD=degistir-beni-guclu-bir-sifre
